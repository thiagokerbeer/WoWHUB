# Server
PORT=3333
NODE_ENV=development

# Database (PostgreSQL — Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/wowhub"

# Auth
JWT_SECRET="replace_with_a_strong_secret_at_least_32_chars"

# Frontend origin allowed by CORS
FRONTEND_URL="http://localhost:5173"

# Cloudflare Turnstile (optional — set TURNSTILE_ENABLED=true to activate)
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=""

# Upstash Redis rate limiting (optional — falls back to in-memory if not set)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
